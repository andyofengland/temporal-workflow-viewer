@page "/"

<PageTitle>Home - Workflow Dashboard</PageTitle>

<h1>Workflow Dashboard</h1>

<div class="row mt-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Upload Workflows</h5>
                <p class="card-text">Upload a zip file containing workflow DLLs to discover and visualize Temporal workflows.</p>
                <a href="/upload" class="btn btn-primary">Upload Now</a>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">View Workflows</h5>
                <p class="card-text">Browse all discovered workflows and view their Mermaid diagrams.</p>
                <a href="/workflows" class="btn btn-primary">View Workflows</a>
            </div>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <p>This dashboard allows you to:</p>
                <ul>
                    <li>Upload zip files containing Temporal workflow DLLs</li>
                    <li>Discover workflows automatically from uploaded assemblies</li>
                    <li>View workflow diagrams in Mermaid format</li>
                    <li>Explore workflow structures and relationships</li>
                </ul>
            </div>
        </div>
    </div>
</div>
